FROM fedora:42

ENV KEYSTONE_VERSION=25.0.0     PYTHONUNBUFFERED=1

RUN dnf install -y python3 python3-pip python3-devel gcc \
                   libffi-devel mariadb curl git httpd mod_wsgi && \
    pip3 install --upgrade pip && \
    pip3 install keystone==$KEYSTONE_VERSION pymysql && \
    useradd -r -s /sbin/nologin keystone && \
    mkdir -p /etc/keystone /var/log/keystone /var/lib/keystone && \
    dnf clean all

COPY entrypoint.sh /entrypoint.sh
COPY keystone-setup.sh /usr/local/bin/keystone-setup.sh
COPY keystone-httpd.conf /etc/httpd/conf.d/keystone.conf
COPY keystone-wsgi-public /usr/local/bin/keystone-wsgi-public
COPY keystone-wsgi-admin /usr/local/bin/keystone-wsgi-admin

RUN chmod +x /entrypoint.sh /usr/local/bin/keystone-setup.sh /usr/local/bin/keystone-wsgi-*
RUN chown -R keystone:keystone /var/lib/keystone /var/log/keystone

EXPOSE 5000 35357

ENTRYPOINT ["/entrypoint.sh"]
