FROM fedora:42

ENV KEYSTONE_VERSION=25.0.0 PYTHONUNBUFFERED=1

RUN dnf install -y python3 python3-pip python3-devel gcc libffi-devel mariadb curl git httpd mod_wsgi && \
    pip3 install --upgrade pip && \
    pip3 install keystone==$KEYSTONE_VERSION pymysql && \
    mkdir -p /etc/keystone /var/log/keystone /var/lib/keystone && \
    dnf clean all

COPY entrypoint.sh /entrypoint.sh
COPY keystone-httpd.conf /etc/httpd/conf.d/keystone.conf

RUN chmod +x /entrypoint.sh

EXPOSE 5000

ENTRYPOINT ["/entrypoint.sh"]